PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# eGov SSO
SSO_BASE_URL=https://hackathon-sso.e.gov.ph
SSO_PARTNER_CODE=your_partner_code
SSO_PARTNER_SECRET=your_partner_secret
# Scope for /api/token — defaults to SSO_AUTHENTICATION when left blank:
SSO_SCOPE=SSO_AUTHENTICATION

# eVerify (National ID)
EVERIFY_BASE_URL=https://hackathon-everify-api.e.gov.ph
EVERIFY_CLIENT_ID=your_client_id
EVERIFY_CLIENT_SECRET=your_client_secret

# eGov AI
EGOVAI_BASE_URL=https://egov-ai-core-ws.oueg.info
EGOVAI_ACCESS_CODE=your_access_code

# eMessage
EMESSAGE_BASE_URL=https://ws-message.e.gov.ph
EMESSAGE_TOKEN=your_emessage_token

# Demo resilience flags — "true" = return fixture instead of calling gov API
SSO_MOCK=false
EVERIFY_MOCK=false
AI_MOCK=true
SMS_MOCK=false
